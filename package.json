{
	"name": "z-interact",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:wrangler": "wrangler pages dev .svelte-kit/cloudflare --compatibility-date=2024-01-01",
		"dev:local": "npm run build && wrangler pages dev .svelte-kit/cloudflare --compatibility-date=2024-01-01 --live-reload",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.3",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.0",
		"@types/node": "^22.19.11",
		"@types/qrcode": "^1.5.6",
		"drizzle-kit": "^0.31.9",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^16.5.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.53.2",
		"svelte-check": "^4.4.3",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1",
		"wrangler": "^4.67.0"
	},
	"dependencies": {
		"@fal-ai/client": "^1.9.3",
		"@libsql/client": "^0.14.0",
		"@neoconfetti/svelte": "^2.2.2",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.40.1",
		"drizzle-valibot": "^0.4.2",
		"flowbite": "^3.1.2",
		"flowbite-svelte": "^1.31.0",
		"flowbite-svelte-icons": "^3.1.0",
		"qrcode": "^1.5.4",
		"tailwind-merge": "^3.5.0",
		"valibot": "^1.2.0"
	}
}
